generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id         Int          @id @default(autoincrement())
  clerkId    String?      @unique
  email         String          @unique
  name          String?
  rewardPoints  Int             @default(0)
  complaints    Complaints[]
  disputeAlerts DisputeAlerts[]
}

model Complaints {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  userId      Int
  user        Users      @relation(fields: [userId], references: [id])
  latitude    Float?
  longitude   Float?
  userEmail   String?
  resolutionNote String?
  status      StatusEnum @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  disputeAlerts DisputeAlerts[]
}

model DisputeAlerts {
  id                Int               @id @default(autoincrement())
  complaintId       Int
  complaint         Complaints        @relation(fields: [complaintId], references: [id])
  userId            Int
  user              Users             @relation(fields: [userId], references: [id])
  userEmail         String
  userMessage       String
  assistantResponse String
  urgentReason      String?
  status            DisputeAlertStatus @default(OPEN)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

enum StatusEnum {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum DisputeAlertStatus {
  OPEN
  REVIEWED
  DISMISSED
}
